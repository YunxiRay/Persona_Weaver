# ============================================================
# Persona Weaver — 生产环境变量模板
# 复制此文件为 .env.production 并填入实际值
# 启动: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ============================================================

# ── 应用 ──
APP_NAME=persona-weaver
HTTP_PORT=80

# ── 数据库 ──
POSTGRES_USER=persona
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=persona_weaver

# ── Redis ──
REDIS_PASSWORD=change-me-to-another-strong-password

# ── 嵌入模型 ──
# bge-large-zh 首次启动时会自动下载（约 1.3GB），后续使用缓存
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5

# ── 推理引擎 ──
INFERENCE_CONVERGENCE_THRESHOLD=0.08
INFERENCE_MIN_EFFECTIVE_WORDS=300
INFERENCE_MAX_TURNS=50
INFERENCE_LIGHT_REPORT_WORDS=600

# ── 安全 ──
# 用于 session token 签名的密钥（务必修改为随机字符串）
SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars

# 危机关键词（逗号分隔，检测到即触发安全熔断）
CRISIS_KEYWORDS=自杀,自伤,结束生命,不想活,自残,伤害自己

# 心理援助热线（展示给用户）
CRISIS_HELPLINE=心理援助热线：12320（24小时）

# ── CORS ──
# 生产环境填写实际域名，多个用逗号分隔
CORS_ORIGINS=http://localhost,https://your-domain.com
