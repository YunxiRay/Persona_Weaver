# =====================================================
# Persona Weaver 后端环境变量
# 复制此文件为 .env 并填入你的测试 Key
# =====================================================

# ── 应用 ──
APP_NAME=persona-weaver
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://persona:persona_dev@localhost:5432/persona_weaver
DATABASE_URL_SYNC=postgresql://persona:persona_dev@localhost:5432/persona_weaver

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── 开发者本地 LLM 测试 Key (仅用于本地调试) ──
DEV_LLM_PROVIDER=deepseek
DEV_LLM_API_KEY=sk-xxxxx
DEV_LLM_BASE_URL=https://api.deepseek.com
DEV_LLM_MODEL=deepseek-v4-pro
DEV_LLM_MAX_RETRIES=3
DEV_LLM_REQUEST_TIMEOUT=30

# ── 嵌入模型 ──
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5

# ── 推理引擎 ──
INFERENCE_CONVERGENCE_THRESHOLD=0.08
INFERENCE_MIN_EFFECTIVE_WORDS=300
INFERENCE_MAX_TURNS=50
INFERENCE_LIGHT_REPORT_WORDS=600

# ── 安全 ──
SECRET_KEY=change-me-in-production
CRISIS_KEYWORDS=自杀,自伤,结束生命,不想活,自残,伤害自己
CRISIS_HELPLINE=心理援助热线：12320（24小时）

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173"]

# ── 日志 ──
LOG_LEVEL=DEBUG
LOG_FORMAT=json
